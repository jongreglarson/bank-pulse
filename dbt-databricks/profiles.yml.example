# Copy to ~/.dbt/profiles.yml and fill in your values.
# This file documents the expected structure — never commit the real profiles.yml.

bank_pulse_databricks:
  target: dev
  outputs:
    dev:
      type: databricks
      host: "{{ env_var('DATABRICKS_HOST') }}"        # e.g. community.cloud.databricks.com (no https://)
      http_path: "{{ env_var('DATABRICKS_HTTP_PATH') }}"  # cluster JDBC/ODBC HTTP path
      token: "{{ env_var('DATABRICKS_TOKEN') }}"
      schema: bank_pulse_dev                           # default schema; overridden per layer in dbt_project.yml
      threads: 1                                       # Community Edition: single cluster, keep at 1
