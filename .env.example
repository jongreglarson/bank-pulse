# Copy this file to .env and fill in your values. Never commit .env.

# Databricks (Community Edition)
# HOST: your workspace URL, e.g. https://community.cloud.databricks.com
# HTTP_PATH: from cluster → Advanced Options → JDBC/ODBC tab
# TOKEN: User Settings → Developer → Access Tokens → Generate new token
DATABRICKS_HOST=https://community.cloud.databricks.com
DATABRICKS_TOKEN=dapi...
DATABRICKS_HTTP_PATH=/sql/protocolv1/o/0/your-cluster-id
DATABRICKS_DATABASE=bank_pulse

# Snowflake
# ACCOUNT: your account identifier (e.g. xy12345.us-east-1)
# Find it: Snowflake UI → bottom-left account menu → account identifier
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=BANK_PULSE
SNOWFLAKE_ROLE=SYSADMIN
